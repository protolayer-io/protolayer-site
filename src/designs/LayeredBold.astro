---
// Design 1b "Layered / Bold" — giant display, animated layers, emerald CTA.
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/layered-bold/Hero.astro';
import Principles from '../components/layered-bold/Principles.astro';
import About from '../components/layered-bold/About.astro';
import Projects from '../components/layered-bold/Projects.astro';
import ContactCta from '../components/layered-bold/ContactCta.astro';
import { defaultLang, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
---

<Base lang={lang} page="home">
  <Nav showThemeLabel lang={lang} />
  <main>
    <Hero lang={lang} />
    <Principles lang={lang} />
    <About lang={lang} />
    <Projects lang={lang} />
    <ContactCta lang={lang} />
  </main>
  <Footer variant="legal" lang={lang} />
</Base>
