---
// Design 1a "Terminal Editorial" — sober, structural, terminal-forward.
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/terminal-editorial/Hero.astro';
import Principles from '../components/terminal-editorial/Principles.astro';
import About from '../components/terminal-editorial/About.astro';
import Projects from '../components/terminal-editorial/Projects.astro';
import ContactLegal from '../components/terminal-editorial/ContactLegal.astro';
import { defaultLang, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
---

<Base lang={lang} page="home">
  <Nav lang={lang} />
  <main>
    <Hero lang={lang} />
    <Principles lang={lang} />
    <About lang={lang} />
    <Projects lang={lang} />
    <ContactLegal lang={lang} />
  </main>
  <Footer variant="simple" lang={lang} />
</Base>
