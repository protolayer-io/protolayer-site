---
import '../styles/tokens.css';
import '../styles/global.css';
import LangDetect from '../components/LangDetect.astro';
import { getSite, type Lang } from '../i18n/ui';
import { defaultLang, langCodes, localizedPath } from '../i18n/utils';

interface Props {
  lang?: Lang;
  /** Which page this is, for hreflang alternates and locale detection. */
  page?: 'home';
  title?: string;
  description?: string;
}

const { lang = defaultLang, page = 'home', title, description } = Astro.props;
const site = getSite(lang);

const pageTitle = title ?? site.meta.title;
const pageDescription = description ?? site.meta.desc;

const alternates = langCodes.map((code) => ({
  code,
  href: new URL(localizedPath(code, page), Astro.site).href,
}));
const defaultHref = new URL(localizedPath(defaultLang, page), Astro.site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {alternates.map((alt) => <link rel="alternate" hreflang={alt.code} href={alt.href} />)}
    <link rel="alternate" hreflang="x-default" href={defaultHref} />

    {lang === defaultLang && <LangDetect page={page} />}

    <!-- Theme init: runs before paint to avoid a flash of the wrong theme. -->
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        const mode =
          saved === 'light' || saved === 'dark'
            ? saved
            : matchMedia('(prefers-color-scheme: light)').matches
              ? 'light'
              : 'dark';
        document.documentElement.setAttribute('data-theme', mode);
      })();
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <slot />

    <!-- Scroll reveals -->
    <script>
      const revealElements = Array.from(
        document.querySelectorAll<HTMLElement>('[data-reveal]')
      );
      const prefersReducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReducedMotion) {
        revealElements.forEach((el) => el.classList.add('is-revealed'));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              const el = entry.target as HTMLElement;
              const index = revealElements.indexOf(el);
              el.style.transitionDelay = `${Math.min((index % 4) * 70, 260)}ms`;
              el.classList.add('is-revealed');
              observer.unobserve(el);
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        revealElements.forEach((el) => observer.observe(el));

        // Safety: force-reveal anything already in view in case the observer never fires.
        setTimeout(() => {
          revealElements.forEach((el) => {
            const rect = el.getBoundingClientRect();
            if (rect.top < innerHeight && rect.bottom > 0) el.classList.add('is-revealed');
          });
        }, 500);
      }
    </script>
  </body>
</html>
