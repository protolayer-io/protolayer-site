---
// Choke landing page — implements option 1a from the Choke Landing design.
// Standalone page: Choke has its own brand (palette + fonts), separate from
// the ProtoLayer site tokens.
import '../styles/choke.css';
import { CHOKE_TITLE, CHOKE_DESCRIPTION } from '../components/choke/config';
import Nav from '../components/choke/Nav.astro';
import Hero from '../components/choke/Hero.astro';
import ScoringStrip from '../components/choke/ScoringStrip.astro';
import Features from '../components/choke/Features.astro';
import HowItWorks from '../components/choke/HowItWorks.astro';
import Showcase from '../components/choke/Showcase.astro';
import LiveResults from '../components/choke/LiveResults.astro';
import Screens from '../components/choke/Screens.astro';
import Faq from '../components/choke/Faq.astro';
import Cta from '../components/choke/Cta.astro';
import Footer from '../components/choke/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{CHOKE_TITLE}</title>
    <meta name="description" content={CHOKE_DESCRIPTION} />
    <link rel="icon" type="image/svg+xml" href="/choke/favicon.svg" />
    <link rel="canonical" href="https://protolayer.io/choke" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={CHOKE_TITLE} />
    <meta property="og:description" content={CHOKE_DESCRIPTION} />
    <meta property="og:url" content="https://protolayer.io/choke" />
    <meta property="og:image" content="https://protolayer.io/choke/screen-scoring.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <div class="page">
      <div class="glow glow-green" aria-hidden="true"></div>
      <div class="glow glow-gold" aria-hidden="true"></div>
      <Nav />
      <main>
        <Hero />
        <ScoringStrip />
        <Features />
        <HowItWorks />
        <Showcase />
        <LiveResults />
        <Screens />
        <Faq />
        <Cta />
      </main>
      <Footer />
    </div>
  </body>
</html>

<style>
  .page {
    position: relative;
    overflow: hidden;
  }

  .glow {
    position: absolute;
    z-index: -1;
    pointer-events: none;
  }

  .glow-green {
    top: -260px;
    left: 50%;
    width: 900px;
    height: 600px;
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, rgba(27, 163, 78, 0.22), transparent 70%);
  }

  .glow-gold {
    top: 400px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(245, 184, 0, 0.1), transparent 70%);
  }
</style>
