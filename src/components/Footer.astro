---
import Logo from './Logo.astro';
import { COPYRIGHT_YEAR, REGISTRY_CODE, REGISTERED_ADDRESS } from '../site.config';
import { getSite, type Lang } from '../i18n/ui';
import { defaultLang } from '../i18n/utils';

interface Props {
  /**
   * 'simple' → logo + copyright + tagline (design 1a; legal lives in its own section).
   * 'legal'  → copyright + registry info + address + tagline (design 1b).
   */
  variant?: 'simple' | 'legal';
  lang?: Lang;
}

const { variant = 'simple', lang = defaultLang } = Astro.props;
const site = getSite(lang);
---

<footer class="footer">
  {
    variant === 'simple' ? (
      <div class="footer-brand">
        <Logo size={18} />
        <span class="footer-text">© {COPYRIGHT_YEAR} ProtoLayer OÜ</span>
      </div>
    ) : (
      <div class="footer-text footer-legal" id="legal">
        © {COPYRIGHT_YEAR} ProtoLayer OÜ · {site.footer.reg} {REGISTRY_CODE}
        <br />
        {REGISTERED_ADDRESS}
      </div>
    )
  }
  <span class="footer-text">{site.footer.tagline}</span>
</footer>

<style>
  .footer {
    padding: 26px var(--page-pad) 34px;
    border-top: 1px solid var(--border-soft);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .footer-text {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted-2);
  }

  .footer-legal {
    line-height: 1.7;
  }
</style>
