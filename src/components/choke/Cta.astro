---
import PlayBadge from './PlayBadge.astro';
import { getChoke, type Lang } from '../../i18n/ui';
import { defaultLang } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = getChoke(lang).cta;
---

<section class="cta container">
  <div class="banner">
    <div class="banner-glow" aria-hidden="true"></div>
    <div class="inner">
      <div>
        <h2>{t.title}</h2>
        <p>{t.subtitle}</p>
      </div>
      <PlayBadge variant="ink" lang={lang} />
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    z-index: 10;
    padding-top: 70px;
    padding-bottom: 20px;
  }

  .banner {
    position: relative;
    background: linear-gradient(150deg, var(--green-deep), #0f7a38);
    border-radius: 26px;
    padding: 60px 52px;
    overflow: hidden;
  }

  .banner-glow {
    position: absolute;
    top: -120px;
    right: -60px;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(245, 184, 0, 0.35), transparent 70%);
  }

  .inner {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(30px, 4vw, 40px);
    line-height: 1.08;
    letter-spacing: -1px;
    color: #fff;
  }

  p {
    font-size: 17px;
    color: rgba(255, 255, 255, 0.85);
    margin-top: 12px;
    max-width: 520px;
  }

  @media (max-width: 720px) {
    .banner {
      padding: 40px 28px;
    }
  }
</style>
