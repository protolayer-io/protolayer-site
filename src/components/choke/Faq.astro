---
import { getChoke, type Lang } from '../../i18n/ui';
import { defaultLang } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = getChoke(lang).faq;
---

<section class="faq container" id="faq">
  <div class="head">
    <span class="kicker">{t.kicker}</span>
    <h2 class="section-title">{t.title}</h2>
  </div>
  <div class="list">
    {
      t.items.map((item, i) => (
        <details open={i === 0}>
          <summary>
            {item.q}
            <span class="plus">+</span>
          </summary>
          <p set:html={item.a} />
        </details>
      ))
    }
  </div>
</section>

<style>
  .faq {
    position: relative;
    z-index: 10;
    max-width: 900px;
    padding-top: 96px;
    padding-bottom: 40px;
  }

  .head {
    text-align: center;
    margin-bottom: 44px;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  details {
    background: var(--surface);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    padding: 20px 24px;
  }

  summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    color: var(--text);
    list-style: none;
    cursor: pointer;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  .plus {
    color: var(--green);
    font-size: 24px;
    line-height: 1;
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  details[open] .plus {
    transform: rotate(45deg);
  }

  details p {
    font-size: 15.5px;
    line-height: 1.65;
    color: var(--muted);
    margin-top: 14px;
  }

  details p :global(.gold-link) {
    color: var(--gold);
  }
</style>
