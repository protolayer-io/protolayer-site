---
import { getChoke, type Lang } from '../../i18n/ui';
import { defaultLang } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = getChoke(lang).how;

const steps = t.steps.map((step, i) => ({
  number: String(i + 1).padStart(2, '0'),
  gold: i === t.steps.length - 1,
  ...step,
}));
---

<section class="how container" id="how">
  <div class="head">
    <span class="kicker">{t.kicker}</span>
    <h2 class="section-title">{t.title}</h2>
  </div>
  <div class="grid">
    {
      steps.map((step) => (
        <article class="step">
          <span class:list={['number', { gold: step.gold }]}>{step.number}</span>
          <h3>{step.title}</h3>
          <p set:html={step.desc} />
        </article>
      ))
    }
  </div>
</section>

<style>
  .how {
    position: relative;
    z-index: 10;
    padding-top: 96px;
    padding-bottom: 40px;
  }

  .head {
    text-align: center;
    max-width: 620px;
    margin: 0 auto;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 24px;
    margin-top: 52px;
  }

  .step {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px 28px;
  }

  .number {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 700;
    color: rgba(34, 197, 94, 0.22);
    line-height: 1;
  }

  .number.gold {
    color: rgba(245, 184, 0, 0.28);
  }

  h3 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    margin: 10px 0 8px;
  }

  p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--muted);
  }

  p :global(.match-id) {
    font-family: var(--font-mono);
    color: var(--green);
  }

  p :global(.gold-link) {
    color: var(--gold);
  }

  p :global(b) {
    color: var(--text);
  }

  @media (max-width: 1024px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
