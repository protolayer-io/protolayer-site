---
interface Props {
  size?: number;
}

const { size = 38 } = Astro.props;
const radius = Math.round(size * 0.29);
---

<span class="logo" style={`width:${size}px; height:${size}px; border-radius:${radius}px;`}>
  <img src="/choke/choke-logo-transp-256.png" alt="" width="256" height="256" />
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
    background: #D6DAE2;
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.35);
  }

  .logo img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
</style>
