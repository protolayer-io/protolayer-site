---
// App screenshots gallery — four phone frames plus two wide detail shots.
import { getChoke, type Lang } from '../../i18n/ui';
import { defaultLang } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = getChoke(lang).screens;

const phones = [
  { src: '/choke/screen-home.jpg', caption: t.cap1 },
  { src: '/choke/screen-settings.jpg', caption: t.cap2 },
  { src: '/choke/screen-account.jpg', caption: t.cap3 },
  { src: '/choke/screen-empty.jpg', caption: t.cap4 },
];

const wide = [
  { src: '/choke/screen-howended.jpg', alt: t.wide1 },
  { src: '/choke/screen-technique.jpg', alt: t.wide2 },
];
---

<section class="screens container" id="screens">
  <div class="head">
    <span class="kicker">{t.kicker}</span>
    <h2 class="section-title">{t.title}</h2>
  </div>
  <div class="phones">
    {
      phones.map((shot) => (
        <figure class="phone-item">
          <div class="frame">
            <img src={shot.src} alt={shot.caption} loading="lazy" />
          </div>
          <figcaption>{shot.caption}</figcaption>
        </figure>
      ))
    }
  </div>
  <div class="wide">
    {
      wide.map((shot) => (
        <div class="wide-item">
          <img src={shot.src} alt={shot.alt} loading="lazy" />
        </div>
      ))
    }
  </div>
</section>

<style>
  .screens {
    position: relative;
    z-index: 10;
    padding-top: 96px;
    padding-bottom: 40px;
  }

  .head {
    max-width: 620px;
  }

  .phones {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 44px;
  }

  .phone-item {
    text-align: center;
  }

  .frame {
    border-radius: 26px;
    padding: 7px;
    background: #000;
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 20px 45px rgba(0, 0, 0, 0.5);
  }

  .frame img {
    display: block;
    width: 100%;
    border-radius: 20px;
  }

  figcaption {
    font-size: 14px;
    font-weight: 600;
    color: var(--muted);
    margin-top: 14px;
  }

  .wide {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 20px;
  }

  .wide-item {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border-strong);
  }

  .wide-item img {
    display: block;
    width: 100%;
  }

  @media (max-width: 1024px) {
    .phones {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 720px) {
    .wide {
      grid-template-columns: 1fr;
    }
  }
</style>
