---
import { LIVE_URL } from './config';
import { getChoke, type Lang } from '../../i18n/ui';
import { defaultLang } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = getChoke(lang).live;
---

<section class="live container" id="live">
  <div class="grid">
    <div class="copy">
      <div class="live-badge">
        <span class="dot"></span>
        {t.badge}
      </div>
      <h2 class="section-title">{t.title}</h2>
      <p class="lead" set:html={t.leadHtml} />
      <div class="howto">
        <p class="howto-title">{t.howtoTitle}</p>
        <ol>
          <li set:html={t.step1Html} />
          <li set:html={t.step2Html} />
          <li>{t.step3}</li>
        </ol>
      </div>
    </div>

    <div class="board">
      <div class="chrome">
        <span class="win-dot red"></span>
        <span class="win-dot gold"></span>
        <span class="win-dot green"></span>
        <div class="url">🔒 bjjscore.live</div>
      </div>
      <div class="board-body">
        <div class="status">
          <span class="tick-dot"></span>
          <span class="clock">02:36</span>
          <span class="pill">{t.inProgress}</span>
        </div>
        <div class="scores">
          <div class="fighter red-side">
            <div class="fighter-name"><span class="fighter-dot"></span>Gordon Ryan</div>
            <div class="score">26</div>
            <div class="stats"><span>A:1</span><span>P:0</span></div>
          </div>
          <div class="fighter blue-side">
            <div class="fighter-name"><span class="fighter-dot"></span>Mike Tyson</div>
            <div class="score">0</div>
            <div class="stats"><span>A:0</span><span>P:0</span></div>
          </div>
        </div>
        <div class="board-footer">Match #3b3f · {t.updating}</div>
      </div>
    </div>
  </div>
</section>

<style>
  .live {
    position: relative;
    z-index: 10;
    padding-top: 96px;
    padding-bottom: 40px;
  }

  .grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: 52px;
    align-items: center;
  }

  .live-badge {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(245, 184, 0, 0.1);
    border: 1px solid rgba(245, 184, 0, 0.3);
    padding: 7px 13px;
    border-radius: 100px;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--gold);
    animation: pulse-dot 1.6s infinite;
  }

  .section-title {
    font-size: clamp(30px, 4vw, 42px);
    letter-spacing: -1.1px;
    margin-top: 18px;
  }

  .lead {
    font-size: 17px;
    line-height: 1.6;
    color: var(--muted);
    margin: 18px 0 22px;
  }

  .lead :global(.gold-link) {
    color: var(--gold);
  }

  .howto {
    background: var(--surface);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 20px 22px;
  }

  .howto-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 10px;
  }

  .howto ol {
    padding-left: 20px;
    font-size: 14.5px;
    line-height: 1.7;
    color: var(--muted);
  }

  .howto :global(b) {
    color: var(--text);
  }

  .howto :global(.gold-link) {
    color: var(--gold);
  }

  .board {
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.55);
    background: var(--bg);
  }

  .chrome {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: var(--surface);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .win-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .win-dot.red {
    background: var(--red);
  }

  .win-dot.gold {
    background: var(--gold);
  }

  .win-dot.green {
    background: var(--green-deep);
  }

  .url {
    margin-left: 12px;
    flex: 1;
    background: rgba(0, 0, 0, 0.4);
    border-radius: 7px;
    padding: 6px 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
  }

  .board-body {
    padding: 30px 28px 34px;
  }

  .status {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-bottom: 22px;
  }

  .tick-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    animation: tick 1.2s infinite;
  }

  .clock {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 1px;
  }

  .pill {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    color: var(--green);
    background: rgba(27, 163, 78, 0.14);
    border: 1px solid rgba(27, 163, 78, 0.35);
    padding: 3px 10px;
    border-radius: 100px;
  }

  .scores {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 16px;
  }

  .fighter {
    border-radius: 16px;
    padding: 20px;
    text-align: center;
  }

  .red-side {
    background: rgba(229, 72, 77, 0.08);
    border: 1px solid rgba(229, 72, 77, 0.35);
  }

  .blue-side {
    background: rgba(59, 130, 246, 0.08);
    border: 1px solid rgba(59, 130, 246, 0.35);
  }

  .fighter-name {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
  }

  .fighter-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .red-side .fighter-dot {
    background: var(--red);
  }

  .blue-side .fighter-dot {
    background: var(--blue);
  }

  .score {
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 700;
    line-height: 1;
  }

  .red-side .score {
    color: var(--red);
  }

  .blue-side .score {
    color: var(--blue);
  }

  .stats {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
  }

  .board-footer {
    text-align: center;
    margin-top: 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted-2);
  }

  @media (max-width: 1024px) {
    .grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (max-width: 480px) {
    .score {
      font-size: 56px;
    }
  }
</style>
