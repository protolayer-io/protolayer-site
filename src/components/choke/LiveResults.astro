---
import { LIVE_URL } from './config';
import { getChoke, type Lang } from '../../i18n/ui';
import { defaultLang } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = getChoke(lang).live;
---

<section class="live container" id="live">
  <div class="grid">
    <div class="copy">
      <div class="live-badge">
        <span class="dot"></span>
        {t.badge}
      </div>
      <h2 class="section-title">{t.title}</h2>
      <p class="lead" set:html={t.leadHtml} />
      <div class="howto">
        <p class="howto-title">{t.howtoTitle}</p>
        <ol>
          <li set:html={t.step1Html} />
          <li set:html={t.step2Html} />
          <li>{t.step3}</li>
        </ol>
      </div>
    </div>

    <div class="board">
      <div class="chrome">
        <span class="win-dot red"></span>
        <span class="win-dot gold"></span>
        <span class="win-dot green"></span>
        <div class="url">🔒 bjjscore.live</div>
      </div>
      <img class="board-shot" src="/choke/gordon-mike.png" alt={t.title} loading="lazy" />
    </div>
  </div>
</section>

<style>
  .live {
    position: relative;
    z-index: 10;
    padding-top: 96px;
    padding-bottom: 40px;
  }

  .grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: 52px;
    align-items: center;
  }

  .live-badge {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(245, 184, 0, 0.1);
    border: 1px solid rgba(245, 184, 0, 0.3);
    padding: 7px 13px;
    border-radius: 100px;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--gold);
    animation: pulse-dot 1.6s infinite;
  }

  .section-title {
    font-size: clamp(30px, 4vw, 42px);
    letter-spacing: -1.1px;
    margin-top: 18px;
  }

  .lead {
    font-size: 17px;
    line-height: 1.6;
    color: var(--muted);
    margin: 18px 0 22px;
  }

  .lead :global(.gold-link) {
    color: var(--gold);
  }

  .howto {
    background: var(--surface);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 20px 22px;
  }

  .howto-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 10px;
  }

  .howto ol {
    padding-left: 20px;
    font-size: 14.5px;
    line-height: 1.7;
    color: var(--muted);
  }

  .howto :global(b) {
    color: var(--text);
  }

  .howto :global(.gold-link) {
    color: var(--gold);
  }

  .board {
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.55);
    background: var(--bg);
  }

  .chrome {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: var(--surface);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .win-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .win-dot.red {
    background: var(--red);
  }

  .win-dot.gold {
    background: var(--gold);
  }

  .win-dot.green {
    background: var(--green-deep);
  }

  .url {
    margin-left: 12px;
    flex: 1;
    background: rgba(0, 0, 0, 0.4);
    border-radius: 7px;
    padding: 6px 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
  }

  .board-shot {
    display: block;
    width: 100%;
  }

  @media (max-width: 1024px) {
    .grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
