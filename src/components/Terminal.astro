---
// Animated terminal card — the brand signature, shared by both designs.
// The terminal is always dark, in both themes, so its inner colors are literal.
---

<div class="terminal" data-reveal>
  <div class="terminal-header">
    <span class="dot"></span>
    <span class="dot"></span>
    <span class="dot dot-active"></span>
    <span class="terminal-title">protolayer — zsh</span>
  </div>
  <div class="terminal-body" data-terminal-body></div>
</div>

<style>
  .terminal {
    background: #080b0c;
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.5);
    text-align: left;
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 15px;
    background: #0c1113;
    border-bottom: 1px solid #16211f;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #2a3a3c;
  }

  .dot-active {
    background: #10b77f;
  }

  .terminal-title {
    font-family: var(--font-mono);
    font-size: 11px;
    color: #62777a;
    margin-left: 8px;
  }

  .terminal-body {
    padding: 20px 18px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.95;
    min-height: 210px;
    color: #b4c4c6;
    white-space: pre-wrap;
  }
</style>

<script>
  const TYPE_START_DELAY_MS = 700;
  const OUTPUT_LINE_INTERVAL_MS = 520;
  // Human keystroke cadence: base delay + random jitter, longer pause at word starts.
  const KEYSTROKE_BASE_MS = 55;
  const KEYSTROKE_JITTER_MS = 110;
  const WORD_PAUSE_MS = 90;
  const POST_COMMAND_PAUSE_MS = 420;

  // Shell prompt (rendered instantly) and the command a "human" types after it.
  const PROMPT_PREFIX_HTML =
    '<span style="color:#10B77F">➜</span> <span style="color:#5F9AA0">~/protolayer</span> <span style="color:#E9EFEF">git:(</span><span style="color:#2DD49A">main</span><span style="color:#E9EFEF">)</span> ';
  const COMMAND_TEXT = 'cargo build --release';

  // Pre-painted output lines (syntax colors per the design spec).
  const OUTPUT_LINES = [
    '<span style="color:#62777A">› compiling modular layers…</span>',
    '  <span style="color:#2DD49A">✓</span> core-protocol    <span style="color:#62777A">compiled in 0.8s</span>',
    '  <span style="color:#2DD49A">✓</span> infra-adapter    <span style="color:#62777A">compiled in 0.6s</span>',
    '  <span style="color:#2DD49A">✓</span> p2p-relay        <span style="color:#62777A">compiled in 1.2s</span>',
    'build complete · <span style="color:#2DD49A">3 layers</span> online',
  ];

  const CURSOR_STYLE =
    'display:inline-block;width:8px;height:15px;background:#10B77F;vertical-align:-2px;animation:pl-blink 1.1s steps(1) infinite;';
  const CURSOR_HTML = `<span style="${CURSOR_STYLE}"></span>`;
  const PROMPT_HTML = `<div><span style="color:#10B77F">$</span> ${CURSOR_HTML}</div>`;

  const prefersReducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  const typeCommand = (terminal: Element, onDone: () => void) => {
    const line = document.createElement('div');
    line.innerHTML = PROMPT_PREFIX_HTML;
    const command = document.createElement('span');
    const cursor = document.createElement('span');
    cursor.setAttribute('style', CURSOR_STYLE);
    line.appendChild(command);
    line.appendChild(cursor);
    terminal.appendChild(line);

    let charIndex = 0;
    const typeNextChar = () => {
      if (charIndex >= COMMAND_TEXT.length) {
        // "Enter" pressed: cursor leaves the command line, output starts.
        cursor.remove();
        setTimeout(onDone, POST_COMMAND_PAUSE_MS);
        return;
      }
      command.textContent += COMMAND_TEXT[charIndex];
      const startsWord = charIndex > 0 && COMMAND_TEXT[charIndex - 1] === ' ';
      charIndex++;
      const delay =
        KEYSTROKE_BASE_MS + Math.random() * KEYSTROKE_JITTER_MS + (startsWord ? WORD_PAUSE_MS : 0);
      setTimeout(typeNextChar, delay);
    };
    typeNextChar();
  };

  document.querySelectorAll('[data-terminal-body]').forEach((terminal) => {
    if (prefersReducedMotion) {
      // No typing animation: render the final state immediately.
      terminal.innerHTML =
        `<div>${PROMPT_PREFIX_HTML}${COMMAND_TEXT}</div>` +
        OUTPUT_LINES.map((line) => `<div>${line}</div>`).join('') +
        PROMPT_HTML;
      return;
    }

    let lineIndex = 0;
    const printNextOutputLine = () => {
      if (lineIndex >= OUTPUT_LINES.length) {
        terminal.innerHTML += PROMPT_HTML;
        return;
      }
      const line = document.createElement('div');
      line.style.animation = 'pl-slide-in 0.25s ease';
      line.innerHTML = OUTPUT_LINES[lineIndex];
      terminal.appendChild(line);
      lineIndex++;
      setTimeout(printNextOutputLine, OUTPUT_LINE_INTERVAL_MS);
    };

    setTimeout(() => typeCommand(terminal, printNextOutputLine), TYPE_START_DELAY_MS);
  });
</script>
