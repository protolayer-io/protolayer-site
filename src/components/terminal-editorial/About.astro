---
// Design 1a — two-column about band on a raised surface.
const tags = ['◇ Distributed systems', '◇ Open protocols', '◇ Resilient infra'];
---

<section class="about" id="about">
  <div class="about-inner container">
    <div data-reveal>
      <p class="mono-label label">01 — About</p>
      <h2>A technology company, not a product shop</h2>
    </div>
    <div data-reveal>
      <p class="copy">
        ProtoLayer OÜ is a technology company registered in Estonia, dedicated to the development
        and support of open-source software and modular digital infrastructure. Our focus is
        modular architecture, distributed systems, and protocol experimentation for emerging
        digital ecosystems.
      </p>
      <div class="tags">
        {tags.map((tag) => <span>{tag}</span>)}
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding: 56px var(--page-pad);
    background: var(--surface-2);
    border-top: 1px solid var(--border-soft);
    border-bottom: 1px solid var(--border-soft);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 44px;
    align-items: start;
  }

  .label {
    color: var(--brand);
    margin-bottom: 14px;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(26px, 3.5vw, 32px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .copy {
    font-size: 16px;
    line-height: 1.7;
    color: var(--muted);
    margin-bottom: 20px;
  }

  .tags {
    display: flex;
    gap: 26px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted-2);
  }

  @media (max-width: 900px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
