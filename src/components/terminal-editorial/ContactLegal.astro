---
// Design 1a — combined legal + contact surface panel.
import { CONTACT_EMAIL, REGISTRY_CODE, REGISTERED_ADDRESS } from '../../site.config';
---

<section class="contact-legal">
  <div class="container">
    <div class="panel" data-reveal>
      <div id="legal">
        <p class="mono-label label">Legal</p>
        <p class="legal-text">
          ProtoLayer OÜ · Reg. no. {REGISTRY_CODE}<br />
          {REGISTERED_ADDRESS}
        </p>
      </div>
      <div class="contact" id="contact">
        <p class="mono-label label">Contact</p>
        <a class="email" href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL} →</a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-legal {
    padding: 0 var(--page-pad) 40px;
  }

  .panel {
    background: var(--surface-2);
    border: 1px solid var(--border-soft);
    border-radius: 16px;
    padding: 28px 30px;
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    justify-content: space-between;
    align-items: center;
  }

  .label {
    letter-spacing: 0.16em;
    color: var(--brand);
    margin-bottom: 10px;
  }

  .legal-text {
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.8;
    color: var(--muted);
  }

  .contact {
    text-align: right;
  }

  .email {
    font-family: var(--font-mono);
    font-size: 15px;
    color: var(--brand-2);
  }

  @media (max-width: 720px) {
    .contact {
      text-align: left;
    }
  }
</style>
