---
// Design 1a — projects grid: Choke card + a dashed "coming soon" slot.
const upcoming = ['More projects\ncoming soon'];
---

<section class="projects" id="projects">
  <div class="container">
    <div class="header" data-reveal>
      <h2>Projects we support</h2>
      <span class="header-tag">02 — Open source</span>
    </div>
    <div class="grid">
      <a class="card project-card" data-reveal href="/choke">
        <div class="card-top">
          <svg
            width="30"
            height="30"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--brand-2)"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 3 19 6.2v5.6c0 4.4-2.9 7.3-7 8.7-4.1-1.4-7-4.3-7-8.7V6.2Z"></path>
            <path d="M9 11.8l2.2 2.2 4.3-4.3"></path>
          </svg>
          <span class="pill">active</span>
        </div>
        <h3>Choke</h3>
        <p>Open-source, real-time BJJ match scoring app with live public scoreboards.</p>
        <span class="link">protolayer.io/choke →</span>
      </a>
      {
        upcoming.map((text) => (
          <div class="card placeholder" data-reveal>
            <svg
              width="26"
              height="26"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--muted-2)"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M12 5v14M5 12h14" />
            </svg>
            <div class="placeholder-text">{text}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects {
    padding: 60px var(--page-pad);
  }

  .header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 26px;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(26px, 3.5vw, 30px);
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .header-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted-2);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }

  .project-card {
    display: block;
    padding: 26px;
    cursor: pointer;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  .pill {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--brand-2);
    background: var(--glow);
    border: 1px solid var(--brand);
    border-radius: 999px;
    padding: 4px 10px;
  }

  h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    color: var(--text);
    margin-bottom: 8px;
  }

  .project-card p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--muted);
    margin-bottom: 18px;
  }

  .link {
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--brand-2);
  }

  .placeholder {
    border-style: dashed;
    border-color: var(--border);
    padding: 26px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    min-height: 190px;
    color: var(--muted-2);
  }

  .placeholder svg {
    margin-bottom: 12px;
  }

  .placeholder-text {
    font-family: var(--font-mono);
    font-size: 12px;
    white-space: pre-line;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
