---
// Design 1b — full-width emerald gradient CTA block with subtle grid texture.
import { CONTACT_EMAIL } from '../../site.config';
import { getSite, type Lang } from '../../i18n/ui';
import { defaultLang } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = getSite(lang).contact;
---

<section class="contact-cta" id="contact">
  <div class="container">
    <div class="cta" data-reveal>
      <div class="texture" aria-hidden="true"></div>
      <div class="cta-inner">
        <h2>{t.title}</h2>
        <p>{t.subtitle}</p>
        <a class="email" href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL} →</a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-cta {
    padding: 0 var(--page-pad) 40px;
  }

  .cta {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--deep), var(--brand));
    border-radius: 20px;
    padding: 48px 40px;
    text-align: center;
  }

  .texture {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 34px 34px;
    opacity: 0.5;
  }

  .cta-inner {
    position: relative;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(26px, 4vw, 32px);
    letter-spacing: -0.02em;
    color: #052a1e;
    margin-bottom: 12px;
  }

  p {
    font-size: 15px;
    color: rgba(5, 42, 30, 0.75);
    margin-bottom: 22px;
  }

  .email {
    display: inline-block;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 14px;
    color: #052a1e;
    background: #e9efef;
    border-radius: 11px;
    padding: 13px 24px;
    transition:
      transform 0.2s,
      box-shadow 0.3s;
  }

  .email:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.2);
  }
</style>
