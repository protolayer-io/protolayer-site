---
// Design 1b — bento grid: large featured Choke tile + a dashed "coming soon" slot.
const upcoming = ['More projects\ncoming soon'];
---

<section class="projects" id="projects">
  <div class="container">
    <div class="header" data-reveal>
      <h2>Projects we support</h2>
      <span class="header-tag">Open source</span>
    </div>
    <div class="grid">
      <a class="card featured" data-reveal href="/choke">
        <div class="corner-glow" aria-hidden="true"></div>
        <div class="featured-inner">
          <div class="card-top">
            <svg
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--brand-2)"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M12 3 19 6.2v5.6c0 4.4-2.9 7.3-7 8.7-4.1-1.4-7-4.3-7-8.7V6.2Z"></path>
              <path d="M9 11.8l2.2 2.2 4.3-4.3"></path>
            </svg>
            <span class="pill">active</span>
          </div>
          <h3>Choke</h3>
          <p>
            Open-source, real-time BJJ match scoring app. Run the table from your phone and
            stream the scoreboard live to spectators — no accounts needed.
          </p>
          <span class="link">protolayer.io/choke →</span>
        </div>
      </a>
      {
        upcoming.map((text) => (
          <div class="card placeholder" data-reveal>
            <div class="placeholder-text">{text}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects {
    padding: 0 var(--page-pad) 70px;
  }

  .header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(26px, 3.5vw, 30px);
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .header-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted-2);
  }

  .grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 16px;
  }

  .featured {
    display: block;
    background: linear-gradient(160deg, var(--surface), var(--surface-2));
    border-radius: 18px;
    padding: 32px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .corner-glow {
    position: absolute;
    top: -40px;
    right: -40px;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, var(--glow), transparent 70%);
  }

  .featured-inner {
    position: relative;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 24px;
  }

  .pill {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--brand-2);
    background: var(--glow);
    border: 1px solid var(--brand);
    border-radius: 999px;
    padding: 5px 12px;
  }

  h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 30px;
    color: var(--text);
    margin-bottom: 12px;
  }

  .featured p {
    font-size: 15px;
    line-height: 1.65;
    color: var(--muted);
    margin-bottom: 24px;
    max-width: 340px;
  }

  .link {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--brand-2);
  }

  .placeholder {
    border-style: dashed;
    border-color: var(--border);
    border-radius: 18px;
    padding: 26px;
    min-height: 150px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: var(--muted-2);
    align-self: stretch;
  }

  .placeholder-text {
    font-family: var(--font-mono);
    font-size: 12px;
    white-space: pre-line;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
