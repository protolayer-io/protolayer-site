---
// Design 1b — centered about section.
import { getSite, type Lang } from '../../i18n/ui';
import { defaultLang } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = getSite(lang).about;
---

<section class="about" id="about">
  <div class="container">
    <p class="mono-label label" data-reveal>{t.label}</p>
    <h2 data-reveal>{t.title}</h2>
    <p class="copy" data-reveal>{t.copy}</p>
  </div>
</section>

<style>
  .about {
    padding: 70px var(--page-pad);
    text-align: center;
  }

  .label {
    color: var(--brand);
    margin-bottom: 18px;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 4vw, 36px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--text);
    max-width: 720px;
    margin: 0 auto 20px;
  }

  .copy {
    font-size: 17px;
    line-height: 1.7;
    color: var(--muted);
    max-width: 640px;
    margin: 0 auto;
  }
</style>
